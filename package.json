{
    "name": "osm-phone-report",
    "version": "5.9.0",
    "description": "A GitHub Pages site that reports invalid phone numbers from OpenStreetMap data.",
    "type": "module",
    "main": "src/main.js",
    "scripts": {
        "download-icons": "node src/download-icons.js",
        "start": "npm run build",
        "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest",
        "build:css": "npx @tailwindcss/cli -i src/input.css -o build/phone/styles.css && npx @tailwindcss/cli -i src/input.css -o build/name/styles.css && npx @tailwindcss/cli -i src/input.css -o build/hours/styles.css",
        "build:history": "node src/history-processor.js",
        "build:progress": "node src/html-progress.js",
        "build": "node src/main.js && npm run build:history && npm run build:progress && npm run build:css",
        "bot:autofix": "node src/osm-safe-edits.js"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@fortawesome/fontawesome-free": "^7.2.0",
        "@mapbox/maki": "^8.2.0",
        "@node-minify/cli": "^10.5.0",
        "@node-minify/jsonminify": "^10.5.0",
        "@openstreetmap/id-tagging-schema": "^6.17.0",
        "@rapideditor/temaki": "^5.13.0",
        "@semantic-release/changelog": "^6.0.3",
        "@semantic-release/git": "^10.0.1",
        "@tailwindcss/cli": "^4.3.0",
        "@turf/turf": "^7.3.5",
        "adm-zip": "^0.5.17",
        "axios": "^1.16.1",
        "chart.js": "^4.5.1",
        "cross-env": "^10.1.0",
        "diff": "^9.0.0",
        "eslint": "^10.4.0",
        "eslint-config-prettier": "^10.1.8",
        "eta": "^4.6.0",
        "globals": "^17.6.0",
        "html-minifier-terser": "^7.0.0",
        "jest": "^30.4.2",
        "js-yaml": "^4.1.1",
        "libphonenumber-js": "^1.13.2",
        "lru-cache": "^11.5.1",
        "node-fetch": "^3.3.2",
        "opening_hours": "^3.12.0",
        "osm-api": "^4.0.0",
        "prettier": "^3.8.3",
        "semantic-release": "^25.0.3",
        "stream-chain": "^4.2.2",
        "stream-json": "^3.2.0",
        "string-similarity-js": "^2.1.4",
        "terser": "^5.47.1",
        "uuid": "^14.0.0"
    },
    "engines": {
        "node": ">=24.0.0",
        "osmium": ">=1.18.0"
    },
    "author": "confusedbuffalo",
    "license": "GNU GPL v3.0"
}
