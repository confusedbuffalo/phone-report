<!DOCTYPE html>
<html lang="<%= it.locale %>" class="">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= it.translate(it.reportType === 'phone' ? 'mainIndexTitle' : it.reportType === 'name' ? 'osmIncompleteNamesValidation' : 'osmOpeningHoursValidation', it.locale) %>
    </title>
    <%~ include("./partials/favicon", { reportType: it.reportType }) %>
    <link href="./styles.css" rel="stylesheet">
    <%~ include("./partials/theme-init") %>
</head>
<body class="body-styles">
    <div class="page-container">
        <header class="page-header">
            <div class="index-header-container">
                <div class="items-start">
                    <div class="theme-toggle-button invisible">
                        <div class="w-7 h-7"></div>
                    </div>
                </div>
                <h1 class="page-title">
                    <%= it.translate(it.reportType === 'phone' ? 'osmPhoneNumberValidation' : it.reportType === 'name' ? 'osmIncompleteNamesValidation' : 'osmOpeningHoursValidation', it.locale) %>
                </h1>
                <div class="items-end">
                    <%~ include("./partials/theme-button") %>
                </div>
            </div>
            <p class="report-subtitle">
                <%= it.translate(it.reportType === 'phone' ? 'reportSubtitle' : it.reportType === 'name' ? 'reportSubtitleNames' : 'reportSubtitleHours', it.locale) %>
            </p>
        </header>

        <div class="card">
            <div class="card-header">
                <h2 class="card-title"><%= it.translate('countryReports', it.locale) %></h2>
                <div class="search-wrapper">
                    <div class="relative">
                        <input type="text" id="region-search" class="search-input" 
                               placeholder="<%= it.translate('searchPlaceholder', it.locale) %>"
                               aria-label="<%= it.translate('searchPlaceholder', it.locale) %>"
                               autocomplete="off">
                        <div class="search-icon-container">
                            <svg class="search-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
                                      d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                            </svg>
                        </div>
                    </div>
                    <div id="autocomplete-results" class="autocomplete-dropdown hidden"></div>
                </div>
                <a href="./progress.html" class="btn-progress">
                    <div class="flex row items-center">
                        <svg class="progress-icon-index" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640">
                            <path d="M128 128C128 110.3 113.7 96 96 96C78.3 96 64 110.3 64 128L64 464C64 508.2 99.8 544 144 544L544 544C561.7 544 576 529.7 576 512C576 494.3 561.7 480 544 480L144 480C135.2 480 128 472.8 128 464L128 128zM534.6 214.6C547.1 202.1 547.1 181.8 534.6 169.3C522.1 156.8 501.8 156.8 489.3 169.3L384 274.7L326.6 217.4C314.1 204.9 293.8 204.9 281.3 217.4L185.3 313.4C172.8 325.9 172.8 346.2 185.3 358.7C197.8 371.2 218.1 371.2 230.6 358.7L304 285.3L361.4 342.7C373.9 355.2 394.2 355.2 406.7 342.7L534.7 214.7z"/>
                        </svg>
                        <div><%= it.translate('progressHistory', it.locale) %></div>
                    </div>
                </a>
            </div>

            <div class="space-y-4">
                <% it.countryStats.forEach(function(country) { 
                    const safeCountryName = country.slug;
                    const countryPageName = safeCountryName + '/';
                    const percentage = country.totalCount > 0 ? (country.invalidCount / country.totalCount) * 100 : 0;
                    const invalidPercentage = Math.max(0, Math.min(100, percentage));
                    const itemLocale = country.locale || it.locale;

                    const formattedInvalid = country.invalidCount.toLocaleString(itemLocale);
                    const formattedTotal = country.totalCount.toLocaleString(itemLocale);

                    const description = it.reportType === 'phone' ?
                        it.translate('invalidNumbersOutOf', itemLocale, { invalid: formattedInvalid, fixable: country.autoFixableCount.toLocaleString(itemLocale), total: formattedTotal })
                            : it.reportType === 'name' ? it.translate('incompleteNamesOutOf', itemLocale, { incomplete: formattedInvalid, total: formattedTotal })
                                : it.translate('invalidHoursOutOf', itemLocale, { invalid: formattedInvalid, fixable: country.autoFixableCount.toLocaleString(itemLocale), total: formattedTotal });
                %>
                    <a href="./<%= countryPageName %>" class="country-link">
                        <div class="country-link-content">
                            <div class="color-indicator" data-percentage="<%= invalidPercentage %>"></div>
                            <div class="country-link-text-container">
                                <h3 class="country-name Kush-text"><%= country.name %></h3>
                                <p class="country-description"><%= description %></p>
                            </div>
                        </div>
                        <div class="country-stats-container">
                            <p class="country-percentage">
                                <%= invalidPercentage.toLocaleString(itemLocale, { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %>
                                <span class="country-percentage-symbol">%</span>
                            </p>
                            <p class="country-invalid-label"><%= it.translate('invalid', itemLocale) %></p>
                        </div>
                    </a>
                <% }) %>
            </div>
        </div>

        <div class="footer-container">
            <%~ include("./partials/footer", { ...it, includeIconAttribution: false }) %>
        </div>
    </div>
    
    <script>
        window.__CONFIG__ = <%~ JSON.stringify(it.indexConfig) %>;
    </script>
    <script type="module" src="./index-search.js"></script>
</body>
</html>